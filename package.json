{
  "name": "hype-kol-dashboard",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbopack -p 3900",
